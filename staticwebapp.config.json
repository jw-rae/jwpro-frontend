{
  "routes": [
    {
      "route": "/apps/planisphere",
      "rewrite": "/apps/planisphere/index.html"
    },
    {
      "route": "/apps/digital-terrain-model-viewer",
      "rewrite": "/apps/digital-terrain-model-viewer/index.html"
    },
    {
      "route": "/index.html",
      "redirect": "/"
    },
    {
      "route": "/api/rss",
      "headers": {
        "Cache-Control": "public, max-age=300, stale-while-revalidate=600"
      }
    },
    {
      "route": "/",
      "rewrite": "/api/server"
    }
  ],
  "platform": {
    "apiRuntime": "node:20"
  },
  "navigationFallback": {
    "rewrite": "/api/server",
    "exclude": [
      "/apps/digital-terrain-model-viewer/data/*",
      "/apps/digital-terrain-model-viewer/assets/*"
    ]
  }
}